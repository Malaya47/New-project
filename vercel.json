{
  "version": 2,
  "rewrites": [
    {
      "source": "/",
      "destination": "/public/index.html"
    },
    {
      "source": "/app.js",
      "destination": "/public/app.js"
    },
    {
      "source": "/styles.css",
      "destination": "/public/styles.css"
    },
    {
      "source": "/invoice/:id",
      "destination": "/api/invoice/:id"
    },
    {
      "source": "/invoice-text/:id",
      "destination": "/api/invoice-text/:id"
    }
  ]
}
